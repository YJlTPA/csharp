<Window x:Class="ProcessMonitor.WPF.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ProcessMonitor.Core.Models;assembly=ProcessMonitor.Core"
        Title="Settings"
        Width="420" Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Appearance" FontWeight="Bold" FontSize="14"
                       Foreground="{StaticResource AccentBlue}" Margin="0,0,0,8"/>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Theme:" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding Themes}"
                          SelectedItem="{Binding Theme}"/>
            </Grid>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Default sort:" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding SortModes}"
                          SelectedItem="{Binding DefaultSortMode}"/>
            </Grid>

            <Separator Margin="0,4"/>

            <TextBlock Text="Auto Refresh" FontWeight="Bold" FontSize="14"
                       Foreground="{StaticResource AccentBlue}" Margin="0,8,0,8"/>

            <CheckBox Content="Enable auto-refresh"
                      IsChecked="{Binding AutoRefresh}" Margin="0,0,0,8"/>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Refresh interval (seconds):" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1"
                         Text="{Binding AutoRefreshIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                         HorizontalAlignment="Stretch"/>
            </Grid>

            <Separator Margin="0,4"/>

            <TextBlock Text="Filters" FontWeight="Bold" FontSize="14"
                       Foreground="{StaticResource AccentBlue}" Margin="0,8,0,8"/>

            <CheckBox Content="Show system processes (PID &lt;= 4)"
                      IsChecked="{Binding ShowSystemProcesses}" Margin="0,0,0,8"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Reset Defaults" Command="{Binding ResetCommand}" Padding="10,5" Margin="0,0,8,0"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Padding="10,5" Margin="0,0,8,0"/>
            <Button Content="Save" Command="{Binding SaveCommand}"
                    Style="{StaticResource AccentButton}" Padding="10,5"/>
        </StackPanel>
    </Grid>
</Window>
