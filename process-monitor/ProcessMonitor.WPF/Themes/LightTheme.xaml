<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background colors -->
    <SolidColorBrush x:Key="WindowBackground"     Color="#F5F5F5"/>
    <SolidColorBrush x:Key="PrimaryBackground"    Color="#F5F5F5"/>
    <SolidColorBrush x:Key="SecondaryBackground"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThirdBackground"      Color="#E8E8EC"/>
    <SolidColorBrush x:Key="SurfaceBackground"    Color="#E8E8EC"/>
    <SolidColorBrush x:Key="SurfaceHover"         Color="#D8D8DC"/>
    <SolidColorBrush x:Key="BorderBrush"          Color="#C0C0C8"/>

    <!-- Text colors -->
    <SolidColorBrush x:Key="PrimaryForeground"    Color="#1A1A2E"/>
    <SolidColorBrush x:Key="SecondaryForeground"  Color="#444460"/>
    <SolidColorBrush x:Key="ForegroundMuted"      Color="#888899"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush"          Color="#1565C0"/>
    <SolidColorBrush x:Key="AccentBlue"           Color="#1565C0"/>
    <SolidColorBrush x:Key="AccentGreen"          Color="#2E7D32"/>
    <SolidColorBrush x:Key="AccentYellow"         Color="#F57F17"/>
    <SolidColorBrush x:Key="AccentRed"            Color="#C62828"/>

    <!-- DataGrid -->
    <SolidColorBrush x:Key="HighlightBrush"               Color="#BBDEFB"/>
    <SolidColorBrush x:Key="DataGridRowBackground"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DataGridAltRowBackground"      Color="#F0F0F5"/>
    <SolidColorBrush x:Key="DataGridHeaderBackground"      Color="#E0E0E8"/>
    <SolidColorBrush x:Key="DataGridSelectedBackground"    Color="#BBDEFB"/>

    <!-- Progress -->
    <SolidColorBrush x:Key="ProgressFill"         Color="#1565C0"/>
    <SolidColorBrush x:Key="ProgressBackground"   Color="#E0E0E8"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonBackground"          Color="#E8E8EC"/>
    <SolidColorBrush x:Key="ButtonHover"               Color="#D8D8DC"/>
    <SolidColorBrush x:Key="ButtonAccent"              Color="#1565C0"/>
    <SolidColorBrush x:Key="ButtonAccentForeground"    Color="#FFFFFF"/>

    <!-- Input -->
    <SolidColorBrush x:Key="InputBackground"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputBorder"          Color="#C0C0C8"/>

    <!-- Bars -->
    <SolidColorBrush x:Key="ToolBarBackground"    Color="#E0E0E8"/>
    <SolidColorBrush x:Key="StatusBarBackground"  Color="#D0D0D8"/>

</ResourceDictionary>
