<UserControl x:Class="KbmTrainer.WPF.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Statistics"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}"
                   Margin="0,0,0,24"/>

        <!-- Summary cards -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,24">
            <!-- Total Sessions -->
            <Border Background="{DynamicResource SecondaryBackground}"
                    CornerRadius="10"
                    Padding="20,16"
                    Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="{Binding TotalSessions}"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentColor}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Total Sessions"
                               FontSize="12"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Best WPM -->
            <Border Background="{DynamicResource SecondaryBackground}"
                    CornerRadius="10"
                    Padding="20,16"
                    Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="{Binding BestWpm}"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="{DynamicResource CorrectColor}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Best WPM"
                               FontSize="12"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Average WPM -->
            <Border Background="{DynamicResource SecondaryBackground}"
                    CornerRadius="10"
                    Padding="20,16"
                    Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock FontSize="32"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center">
                        <TextBlock.Text>
                            <Binding Path="AverageWpm" StringFormat="{}{0:F1}"/>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Text="Avg WPM"
                               FontSize="12"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Average Accuracy -->
            <Border Background="{DynamicResource SecondaryBackground}"
                    CornerRadius="10"
                    Padding="20,16">
                <StackPanel>
                    <TextBlock FontSize="32"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center">
                        <TextBlock.Text>
                            <Binding Path="AverageAccuracy" StringFormat="{}{0:F1}%"/>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Text="Avg Accuracy"
                               FontSize="12"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Session history label -->
        <TextBlock Grid.Row="2"
                   Text="Session History"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondary}"
                   Margin="0,0,0,12"/>

        <!-- DataGrid of sessions -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Sessions}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" Width="150"/>
                <DataGridTextColumn Header="Dictionary" Binding="{Binding DictionaryName}" Width="*"/>
                <DataGridTextColumn Header="WPM" Binding="{Binding Wpm}" Width="80"/>
                <DataGridTextColumn Header="Accuracy" Binding="{Binding Accuracy, StringFormat='{}{0:F1}%'}" Width="90"/>
                <DataGridTextColumn Header="Duration" Binding="{Binding Duration, StringFormat='{}{0:mm\\:ss}'}" Width="90"/>
                <DataGridTextColumn Header="Chars" Binding="{Binding TotalChars}" Width="70"/>
                <DataGridTextColumn Header="Errors" Binding="{Binding ErrorChars}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Clear button -->
        <Button Grid.Row="4"
                Content="Clear History"
                Command="{Binding ClearHistoryCommand}"
                HorizontalAlignment="Right"
                Margin="0,16,0,0"
                Padding="16,8"
                Foreground="{DynamicResource IncorrectColor}"
                BorderBrush="{DynamicResource IncorrectColor}"/>
    </Grid>
</UserControl>
