<UserControl x:Class="KbmTrainer.WPF.Views.TypingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:KbmTrainer.WPF.ViewModels"
             Background="Transparent">

    <Grid Margin="40,32,40,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top bar: stats -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="{Binding DictionaryName}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentColor}"/>
            </StackPanel>

            <!-- WPM -->
            <Border Grid.Column="1"
                    Background="{DynamicResource SecondaryBackground}"
                    CornerRadius="8"
                    Padding="16,8"
                    Margin="0,0,12,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding LiveWpm}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="WPM"
                               FontSize="11"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Accuracy -->
            <Border Grid.Column="2"
                    Background="{DynamicResource SecondaryBackground}"
                    CornerRadius="8"
                    Padding="16,8"
                    Margin="0,0,12,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center">
                        <TextBlock.Text>
                            <Binding Path="LiveAccuracy" StringFormat="{}{0:F1}%" Mode="OneWay"/>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Text="Accuracy"
                               FontSize="11"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Timer -->
            <Border Grid.Column="3"
                    Background="{DynamicResource SecondaryBackground}"
                    CornerRadius="8"
                    Padding="16,8">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding ElapsedText}"
                               FontSize="24"
                               FontWeight="Bold"
                               FontFamily="Consolas"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Time"
                               FontSize="11"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Separator -->
        <Separator Grid.Row="1" Margin="0,0,0,24" Background="{DynamicResource BorderColor}"/>

        <!-- Text display area -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border Background="{DynamicResource SecondaryBackground}"
                    CornerRadius="10"
                    Padding="28,24">
                <ItemsControl ItemsSource="{Binding CharSlots}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:CharSlot}">
                            <TextBlock Text="{Binding ExpectedText}"
                                       FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=20}"
                                       FontFamily="Consolas"
                                       Foreground="{Binding State, Converter={StaticResource CharStateToColorConverter}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding State}" Value="Current">
                                                <Setter Property="TextDecorations" Value="Underline"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </ScrollViewer>

        <!-- Session result banner -->
        <Border Grid.Row="3"
                Background="{DynamicResource SecondaryBackground}"
                CornerRadius="8"
                Padding="20,12"
                Margin="0,20,0,0"
                Visibility="{Binding IsFinished, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource CorrectColor}"
                       HorizontalAlignment="Center">
                <Run Text="Session complete! "/>
                <Run Text="WPM: "/>
                <Run Text="{Binding LiveWpm, Mode=OneWay}"/>
                <Run Text="  Accuracy: "/>
                <Run>
                    <Run.Text>
                        <Binding Path="LiveAccuracy" StringFormat="{}{0:F1}%" Mode="OneWay"/>
                    </Run.Text>
                </Run>
                <Run Text="  Time: "/>
                <Run Text="{Binding ElapsedText, Mode=OneWay}"/>
            </TextBlock>
        </Border>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">
            <Button Content="Restart"
                    Command="{Binding RestartCommand}"
                    Style="{StaticResource AccentButton}"
                    Padding="24,10"
                    FontSize="14"
                    Margin="0,0,12,0"/>
            <Button Content="Change Dictionary"
                    Command="{Binding ChangeDictionaryCommand}"
                    Padding="24,10"
                    FontSize="14"/>
        </StackPanel>
    </Grid>
</UserControl>
